---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
}

const {
  title,
  description = "Master the art of prompting AI models",
  image = "/og-image.png",
  noIndex = false
} = Astro.props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const absoluteImageUrl = new URL(image, siteUrl).toString();
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow"} />
    <meta name="theme-color" content="#0c0a09" />
    <meta property="og:site_name" content="Prompt Atlas" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Prompt Atlas`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={`${title} | Prompt Atlas`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={absoluteImageUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Prompt Atlas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@400;500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@400;500&display=swap"
      />
    </noscript>
  </head>
    <body class="bg-stone-950 text-stone-300 text-base antialiased">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <nav class="fixed top-0 left-0 right-0 z-50 bg-stone-950/90 backdrop-blur-sm border-b border-stone-800/50">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2.5">
            <div class="w-7 h-7 rounded-full bg-stone-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-stone-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <span class="text-sm text-stone-300">
              Prompt Atlas
            </span>
          </a>
          
          <div class="hidden md:flex items-center gap-6">
            <a href="/learn" class="text-sm text-stone-500 hover:text-stone-200 transition-colors">
              Learn
            </a>
            <a href="/learn/real-world-prompts" class="text-sm text-stone-500 hover:text-stone-200 transition-colors">
              Real Prompts
            </a>
          </div>

          <button id="mobile-menu-btn" class="md:hidden p-1 text-stone-500" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle navigation menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <div id="mobile-menu" class="hidden md:hidden bg-stone-950 border-t border-stone-800/50">
        <div class="px-6 py-3 space-y-2">
          <a href="/learn" class="block py-2 text-sm text-stone-500">Learn</a>
          <a href="/learn/real-world-prompts" class="block py-2 text-sm text-stone-500">Real Prompts</a>
        </div>
      </div>
    </nav>

    <main id="main-content" class="pt-16">
      <slot />
    </main>

    <footer class="border-t border-stone-800/50 mt-24">
      <div class="max-w-5xl mx-auto px-6 py-8">
        <p class="text-xs text-stone-500 text-center">
          &copy; {currentYear}
          <a
            href="https://mananjoshi.me"
            target="_blank"
            rel="noopener noreferrer"
            class="ml-1 text-stone-400 hover:text-stone-200 underline underline-offset-2 decoration-stone-600 hover:decoration-stone-300 transition-colors"
          >
            Manan Joshi
          </a>
          <span class="mx-1 text-stone-600">&middot;</span>
          <a
            href="https://github.com/manan30/prompting-guide"
            target="_blank"
            rel="noopener noreferrer"
            class="text-stone-400 hover:text-stone-200 underline underline-offset-2 decoration-stone-600 hover:decoration-stone-300 transition-colors"
          >
            GitHub
          </a>
        </p>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!isExpanded));
      });
    </script>

    <script>
      import { initPostHog } from '../lib/posthog';
      initPostHog();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --font-serif: 'Instrument Serif', Georgia, serif;
    --font-sans: 'DM Sans', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }
  
  body {
    font-family: var(--font-sans);
  }
  
  h1, h2, h3, h4 {
    font-family: var(--font-serif);
    font-weight: 400;
  }

  code, pre {
    font-family: var(--font-mono);
  }

  .gradient-text {
    font-family: var(--font-serif);
    font-style: italic;
  }

  .card-gradient {
    background: linear-gradient(145deg, rgba(35, 35, 35, 0.9) 0%, rgba(20, 20, 20, 0.95) 100%);
    border: 1px solid rgba(80, 80, 80, 0.25);
  }

  ::selection {
    background: rgba(255, 255, 255, 0.15);
  }

  .skip-link {
    position: absolute;
    left: 1rem;
    top: 0.5rem;
    z-index: 100;
    transform: translateY(-200%);
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    background: rgb(28 25 23);
    color: rgb(231 229 228);
    transition: transform 0.2s ease;
  }

  .skip-link:focus-visible {
    transform: translateY(0);
  }
</style>
