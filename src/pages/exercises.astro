---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Exercises">
  <div class="py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-semibold mb-4 text-stone-100">
          Practice Exercises
        </h1>
        <p class="text-stone-400 max-w-xl mx-auto">
          Strengthen your prompting skills with hands-on challenges.
        </p>
      </div>

      <div class="space-y-8">
        <section>
          <h2 class="text-lg font-medium mb-4 text-stone-300">Beginner</h2>
          <div class="space-y-3">
            <div class="card-gradient rounded-lg p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-medium mb-1 text-stone-200">Zero-shot summarization</h3>
                  <p class="text-stone-400 text-sm mb-2">
                    Write a prompt to summarize any news article in exactly 3 bullet points.
                  </p>
                  <div class="flex gap-1.5">
                    <span class="px-2 py-0.5 rounded bg-stone-800 text-xs text-stone-500">Zero-Shot</span>
                  </div>
                </div>
                <a href="/playground" class="px-3 py-1.5 rounded border border-stone-700 text-stone-400 text-xs hover:border-stone-500 hover:text-stone-200 transition-colors">
                  Try
                </a>
              </div>
            </div>

            <div class="card-gradient rounded-lg p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-medium mb-1 text-stone-200">Role-based explanation</h3>
                  <p class="text-stone-400 text-sm mb-2">
                    Create a prompt that explains blockchain to a 10-year-old. Use a teaching persona.
                  </p>
                  <div class="flex gap-1.5">
                    <span class="px-2 py-0.5 rounded bg-stone-800 text-xs text-stone-500">Role-Based</span>
                  </div>
                </div>
                <a href="/playground" class="px-3 py-1.5 rounded border border-stone-700 text-stone-400 text-xs hover:border-stone-500 hover:text-stone-200 transition-colors">
                  Try
                </a>
              </div>
            </div>
          </div>
        </section>

        <section>
          <h2 class="text-lg font-medium mb-4 text-stone-300">Intermediate</h2>
          <div class="space-y-3">
            <div class="card-gradient rounded-lg p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-medium mb-1 text-stone-200">Few-shot classification</h3>
                  <p class="text-stone-400 text-sm mb-2">
                    Build a prompt that classifies reviews as positive, negative, or neutral using 2 examples.
                  </p>
                  <div class="flex gap-1.5">
                    <span class="px-2 py-0.5 rounded bg-stone-800 text-xs text-stone-500">Few-Shot</span>
                  </div>
                </div>
                <a href="/playground" class="px-3 py-1.5 rounded border border-stone-700 text-stone-400 text-xs hover:border-stone-500 hover:text-stone-200 transition-colors">
                  Try
                </a>
              </div>
            </div>

            <div class="card-gradient rounded-lg p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-medium mb-1 text-stone-200">Chain-of-thought math</h3>
                  <p class="text-stone-400 text-sm mb-2">
                    Write a prompt that solves this step-by-step: "A train travels 60 mph for 2 hours..."
                  </p>
                  <div class="flex gap-1.5">
                    <span class="px-2 py-0.5 rounded bg-stone-800 text-xs text-stone-500">CoT</span>
                  </div>
                </div>
                <a href="/playground" class="px-3 py-1.5 rounded border border-stone-700 text-stone-400 text-xs hover:border-stone-500 hover:text-stone-200 transition-colors">
                  Try
                </a>
              </div>
            </div>
          </div>
        </section>

        <section>
          <h2 class="text-lg font-medium mb-4 text-stone-300">Advanced</h2>
          <div class="space-y-3">
            <div class="card-gradient rounded-lg p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-medium mb-1 text-stone-200">Code review agent</h3>
                  <p class="text-stone-400 text-sm mb-2">
                    Create a system prompt that acts as a senior code reviewer.
                  </p>
                  <div class="flex gap-1.5">
                    <span class="px-2 py-0.5 rounded bg-stone-800 text-xs text-stone-500">System</span>
                  </div>
                </div>
                <a href="/playground" class="px-3 py-1.5 rounded border border-stone-700 text-stone-400 text-xs hover:border-stone-500 hover:text-stone-200 transition-colors">
                  Try
                </a>
              </div>
            </div>

            <div class="card-gradient rounded-lg p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-medium mb-1 text-stone-200">Prompt chaining</h3>
                  <p class="text-stone-400 text-sm mb-2">
                    Design a two-step prompt: first summarize, then translate to Spanish.
                  </p>
                  <div class="flex gap-1.5">
                    <span class="px-2 py-0.5 rounded bg-stone-800 text-xs text-stone-500">Chaining</span>
                  </div>
                </div>
                <a href="/playground" class="px-3 py-1.5 rounded border border-stone-700 text-stone-400 text-xs hover:border-stone-500 hover:text-stone-200 transition-colors">
                  Try
                </a>
              </div>
            </div>
          </div>
        </section>
      </div>

      <div class="mt-12 card-gradient rounded-lg p-5">
        <h2 class="text-base font-medium mb-4 text-stone-200">Skills checklist</h2>
        <div class="grid md:grid-cols-2 gap-2.5 text-sm">
          <label class="flex items-center gap-2.5 text-stone-400">
            <input type="checkbox" class="w-4 h-4 rounded bg-stone-800 border-stone-700" />
            <span>Can write effective zero-shot prompts</span>
          </label>
          <label class="flex items-center gap-2.5 text-stone-400">
            <input type="checkbox" class="w-4 h-4 rounded bg-stone-800 border-stone-700" />
            <span>Can use few-shot for format control</span>
          </label>
          <label class="flex items-center gap-2.5 text-stone-400">
            <input type="checkbox" class="w-4 h-4 rounded bg-stone-800 border-stone-700" />
            <span>Can apply chain-of-thought for reasoning</span>
          </label>
          <label class="flex items-center gap-2.5 text-stone-400">
            <input type="checkbox" class="w-4 h-4 rounded bg-stone-800 border-stone-700" />
            <span>Can assign roles effectively</span>
          </label>
        </div>
      </div>
    </div>
  </div>
</Layout>
