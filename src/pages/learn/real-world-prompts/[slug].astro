---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const prompts = await getCollection('real-world-prompts');
  return prompts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const hasContent = Boolean(entry.body?.trim());
const flavors = entry.data.flavors ?? [];
const flavorIdBase = `flavor-${entry.id.replace(/[^a-zA-Z0-9-]/g, '-')}`;
---

<Layout title={entry.data.title} description={entry.data.summary}>
  <div class="py-14 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-stone-400 mb-8">
        <a href="/learn" class="hover:text-white transition-colors">Learn</a>
        <span>/</span>
        <a href="/learn/real-world-prompts" class="hover:text-white transition-colors">Real-World Prompts</a>
        <span>/</span>
        <span class="text-stone-200">{entry.data.title}</span>
      </nav>

      <header class="mb-8 rounded-xl border border-stone-700 bg-stone-900/40 p-6">
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <span class="px-2 py-1 rounded bg-cyan-500/10 border border-cyan-500/30 text-cyan-300 text-xs">
            {entry.data.sourceProject}
          </span>
          <span class="px-2 py-1 rounded border border-stone-600 bg-stone-800 text-stone-300 text-xs">{entry.data.modelFocus}</span>
          <span class="text-xs text-stone-400">Verified {entry.data.verifiedAt}</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-stone-100 mb-3">{entry.data.title}</h1>
        <p class="text-stone-300 mb-5 leading-relaxed">{entry.data.summary}</p>
        <dl class="grid sm:grid-cols-2 gap-3 text-sm text-stone-300" aria-label="Prompt metadata">
          <div>
            <dt class="text-stone-400">Source path</dt>
            <dd><code>{entry.data.sourcePath}</code></dd>
          </div>
          <div>
            <dt class="text-stone-400">License</dt>
            <dd>{entry.data.sourceLicense}</dd>
          </div>
        </dl>
        <div class="mt-4">
          <a
            href={entry.data.sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex px-3 py-2 rounded-lg border border-cyan-500/40 text-cyan-300 hover:bg-cyan-500/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400"
          >
            View source file
          </a>
        </div>
      </header>

      {flavors.length > 0 && (
        <section aria-labelledby="prompt-flavors" class="mb-8">
          <h2 id="prompt-flavors" class="text-2xl font-semibold text-stone-100 mb-4">Prompt Flavors</h2>
          <p class="text-sm text-stone-300 mb-4">Select a flavor to inspect the exact source-linked system prompt excerpt.</p>

          <div class="rounded-xl border border-stone-700 bg-stone-900/30 p-4 md:p-5" data-flavor-switcher>
            <div role="tablist" aria-label="Opencode prompt flavors" class="flex flex-wrap gap-2 mb-4">
              {flavors.map((flavor, index) => (
                <button
                  id={`${flavorIdBase}-tab-${index}`}
                  type="button"
                  role="tab"
                  aria-controls={`${flavorIdBase}-panel-${index}`}
                  aria-selected={index === 0 ? 'true' : 'false'}
                  tabindex={index === 0 ? '0' : '-1'}
                  class="flavor-tab px-3 py-1.5 rounded-lg text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400"
                >
                  {flavor.name}
                </button>
              ))}
            </div>

            {flavors.map((flavor, index) => (
              <section
                id={`${flavorIdBase}-panel-${index}`}
                role="tabpanel"
                aria-labelledby={`${flavorIdBase}-tab-${index}`}
                tabindex={0}
                hidden={index !== 0}
                class="rounded-lg border border-stone-700 bg-stone-950/70 p-4"
              >
                <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
                  <h3 class="text-base font-semibold text-stone-100">{flavor.name}</h3>
                  <a
                    href={flavor.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex px-2.5 py-1.5 rounded-md border border-cyan-500/40 text-cyan-300 text-sm hover:bg-cyan-500/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-400"
                  >
                    View source
                  </a>
                </div>
                <p class="text-sm text-stone-300 mb-2 leading-relaxed">{flavor.focus}</p>
                <p class="text-xs text-stone-400 mb-3"><code>{flavor.sourcePath}</code></p>
                <pre class="overflow-x-auto rounded-lg border border-stone-700 bg-stone-900 p-4 text-sm text-stone-200 leading-relaxed"><code>{flavor.excerpt}</code></pre>
              </section>
            ))}
          </div>
        </section>
      )}

      {hasContent && (
        <article class="rounded-xl border border-stone-700 bg-stone-900/20 p-6 md:p-8 prose prose-invert max-w-none prose-code:text-cyan-300 prose-pre:bg-stone-950 prose-pre:border prose-pre:border-stone-700 prose-headings:text-stone-100 prose-p:text-stone-300 prose-strong:text-stone-100 prose-li:text-stone-300">
          <Content />
        </article>
      )}
    </div>
  </div>
</Layout>

<script>
  const switchers = document.querySelectorAll('[data-flavor-switcher]');

  switchers.forEach((switcher) => {
    const tabs = Array.from(switcher.querySelectorAll('[role="tab"]'));
    const panels = Array.from(switcher.querySelectorAll('[role="tabpanel"]'));

    const setActiveTab = (nextIndex) => {
      tabs.forEach((tab, index) => {
        const isActive = index === nextIndex;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
      });

      panels.forEach((panel, index) => {
        panel.hidden = index !== nextIndex;
      });
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        setActiveTab(index);
      });

      tab.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft' && event.key !== 'Home' && event.key !== 'End') {
          return;
        }

        event.preventDefault();

        let nextIndex = index;
        if (event.key === 'ArrowRight') nextIndex = (index + 1) % tabs.length;
        if (event.key === 'ArrowLeft') nextIndex = (index - 1 + tabs.length) % tabs.length;
        if (event.key === 'Home') nextIndex = 0;
        if (event.key === 'End') nextIndex = tabs.length - 1;

        setActiveTab(nextIndex);
        tabs[nextIndex].focus();
      });
    });
  });
</script>

<style>
  .flavor-tab {
    border: 1px solid rgb(68 64 60);
    background: rgb(28 25 23 / 0.6);
    color: rgb(214 211 209);
  }

  .flavor-tab:hover {
    border-color: rgb(120 113 108);
    color: rgb(245 245 244);
  }

  .flavor-tab[aria-selected="true"] {
    border-color: rgb(34 211 238 / 0.55);
    background: rgb(6 182 212 / 0.12);
    color: rgb(207 250 254);
  }
</style>
