---
import Layout from '../layouts/Layout.astro';
import PromptBuilder from '../components/PromptBuilder';
---

<Layout title="Try It Out">
  <div class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-serif text-stone-100 mb-4">
          Try It Out
        </h1>
        <p class="text-lg text-stone-500 max-w-md mx-auto">
          Experiment with different prompting techniques.
        </p>
      </div>

      <PromptBuilder client:load />

      <div class="mt-16">
        <h2 class="text-xl font-serif text-stone-300 mb-5">Quick tips</h2>
        <div class="grid md:grid-cols-3 gap-px bg-stone-800/50">
          <div class="bg-stone-950 p-5">
            <h3 class="font-serif text-lg text-stone-200 mb-2">Start simple</h3>
            <p class="text-base text-stone-600">Begin with a basic prompt, then add complexity incrementally.</p>
          </div>
          <div class="bg-stone-950 p-5">
            <h3 class="font-serif text-lg text-stone-200 mb-2">Compare techniques</h3>
            <p class="text-base text-stone-600">Try the same task with different approaches to see what works.</p>
          </div>
          <div class="bg-stone-950 p-5">
            <h3 class="font-serif text-lg text-stone-200 mb-2">Save good prompts</h3>
            <p class="text-base text-stone-600">When you find one that works, save it for future use.</p>
          </div>
        </div>
      </div>

      <div class="mt-12">
        <h2 class="text-xl font-serif text-stone-300 mb-5">Technique reference</h2>
        <div class="bg-stone-900/30 border border-stone-800/50 rounded-lg overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full min-w-[680px] text-base">
              <caption class="sr-only">Technique reference table with use cases and examples</caption>
              <thead class="bg-stone-900/50">
                <tr>
                  <th scope="col" class="px-5 py-3 text-left text-stone-400 font-normal">Technique</th>
                  <th scope="col" class="px-5 py-3 text-left text-stone-400 font-normal">When to use</th>
                  <th scope="col" class="px-5 py-3 text-left text-stone-400 font-normal">Example</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-stone-800/50">
                <tr>
                  <td class="px-5 py-3 text-stone-300">Zero-Shot</td>
                  <td class="px-5 py-3 text-stone-500">Simple, well-known tasks</td>
                  <td class="px-5 py-3 font-mono text-xs text-stone-500">"Summarize this..."</td>
                </tr>
                <tr>
                  <td class="px-5 py-3 text-stone-300">Few-Shot</td>
                  <td class="px-5 py-3 text-stone-500">Specific format needed</td>
                  <td class="px-5 py-3 font-mono text-xs text-stone-500">"Example: X → Y"</td>
                </tr>
                <tr>
                  <td class="px-5 py-3 text-stone-300">Chain-of-Thought</td>
                  <td class="px-5 py-3 text-stone-500">Complex reasoning</td>
                  <td class="px-5 py-3 font-mono text-xs text-stone-500">"Think step by step"</td>
                </tr>
                <tr>
                  <td class="px-5 py-3 text-stone-300">Role-Based</td>
                  <td class="px-5 py-3 text-stone-500">Specific tone/expertise</td>
                  <td class="px-5 py-3 font-mono text-xs text-stone-500">"You are an expert..."</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
