---
import Layout from '../layouts/Layout.astro';
import PromptBuilder from '../components/PromptBuilder';
---

<Layout title="Prompt Playground">
  <div class="py-12 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="gradient-text">Prompt Playground</span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto">
          Experiment with different prompting techniques and see how they affect AI responses
        </p>
      </div>

      <!-- Interactive Prompt Builder -->
      <PromptBuilder client:load />

      <!-- Tips Section -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold mb-6">Quick Tips</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="card-gradient rounded-xl p-6">
            <h3 class="font-semibold mb-2 text-emerald-400">Start Simple</h3>
            <p class="text-slate-400 text-sm">Begin with a basic prompt, then add complexity incrementally to see what each change does.</p>
          </div>
          <div class="card-gradient rounded-xl p-6">
            <h3 class="font-semibold mb-2 text-cyan-400">Compare Techniques</h3>
            <p class="text-slate-400 text-sm">Try the same task with zero-shot, few-shot, and chain-of-thought to see the differences.</p>
          </div>
          <div class="card-gradient rounded-xl p-6">
            <h3 class="font-semibold mb-2 text-violet-400">Save Good Prompts</h3>
            <p class="text-slate-400 text-sm">When you find a prompt that works well, save it to your library for future use.</p>
          </div>
        </div>
      </div>

      <!-- Technique Reference -->
      <div class="mt-12">
        <h2 class="text-2xl font-bold mb-6">Technique Quick Reference</h2>
        <div class="card-gradient rounded-xl overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-slate-800/50">
                <tr>
                  <th class="px-6 py-4 text-left text-sm font-semibold text-white">Technique</th>
                  <th class="px-6 py-4 text-left text-sm font-semibold text-white">When to Use</th>
                  <th class="px-6 py-4 text-left text-sm font-semibold text-white">Example Trigger</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-800">
                <tr>
                  <td class="px-6 py-4 text-slate-300">Zero-Shot</td>
                  <td class="px-6 py-4 text-slate-400 text-sm">Simple, well-known tasks</td>
                  <td class="px-6 py-4 font-mono text-sm text-violet-400">"Summarize this..."</td>
                </tr>
                <tr>
                  <td class="px-6 py-4 text-slate-300">Few-Shot</td>
                  <td class="px-6 py-4 text-slate-400 text-sm">Specific format needed</td>
                  <td class="px-6 py-4 font-mono text-sm text-violet-400">"Example: X → Y\nNow do Z"</td>
                </tr>
                <tr>
                  <td class="px-6 py-4 text-slate-300">Chain-of-Thought</td>
                  <td class="px-6 py-4 text-slate-400 text-sm">Complex reasoning</td>
                  <td class="px-6 py-4 font-mono text-sm text-violet-400">"Let's think step by step"</td>
                </tr>
                <tr>
                  <td class="px-6 py-4 text-slate-300">Role-Based</td>
                  <td class="px-6 py-4 text-slate-400 text-sm">Specific tone/expertise</td>
                  <td class="px-6 py-4 font-mono text-sm text-violet-400">"You are an expert..."</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
