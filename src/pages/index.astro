---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Prompt Atlas">
  <div class="relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-stone-900 via-stone-950 to-stone-950"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-6xl font-semibold mb-6 leading-tight text-stone-100">
          Learn to talk to AI in plain English
        </h1>
        
        <p class="text-lg text-stone-400 mb-10 max-w-xl mx-auto">
          A practical guide to getting better responses from ChatGPT, Claude, Gemini and other AI tools.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/learn" class="px-6 py-3 rounded-lg bg-stone-100 text-stone-900 font-medium text-sm hover:bg-stone-200 transition-colors">
            Start Learning
          </a>
          <a href="/learn/real-world-prompts" class="px-6 py-3 rounded-lg border border-stone-700 text-stone-300 font-medium text-sm hover:border-stone-500 hover:text-stone-100 transition-colors">
            Real Prompts
          </a>
        </div>
      </div>
    </div>
  </div>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-2xl md:text-3xl font-semibold mb-4 text-stone-200">Three things that matter</h2>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="card-gradient rounded-xl p-6">
          <h3 class="text-lg font-medium mb-3 text-stone-200">Give context</h3>
          <p class="text-stone-400 text-sm leading-relaxed">
            Tell AI who you are and what you're working on. The more background you give, the better it understands your needs.
          </p>
        </div>
        
        <div class="card-gradient rounded-xl p-6">
          <h3 class="text-lg font-medium mb-3 text-stone-200">Be specific</h3>
          <p class="text-stone-400 text-sm leading-relaxed">
            Vague prompts get vague results. Say exactly what format, length, or tone you want—AI reads instructions literally.
          </p>
        </div>
        
        <div class="card-gradient rounded-xl p-6">
          <h3 class="text-lg font-medium mb-3 text-stone-200">Try again</h3>
          <p class="text-stone-400 text-sm leading-relaxed">
            First drafts are starting points. Refine based on what AI returns—it's a conversation, not a command.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-semibold text-stone-200">Core techniques</h2>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/learn/techniques/zeroshot" class="card-gradient rounded-lg p-5 hover:border-stone-600 transition-colors">
          <div class="text-stone-500 text-xs mb-2">01</div>
          <h3 class="text-base font-medium mb-1 text-stone-200">Zero-Shot</h3>
          <p class="text-stone-500 text-sm">Direct instructions without examples.</p>
        </a>
        
        <a href="/learn/techniques/fewshot" class="card-gradient rounded-lg p-5 hover:border-stone-600 transition-colors">
          <div class="text-stone-500 text-xs mb-2">02</div>
          <h3 class="text-base font-medium mb-1 text-stone-200">Few-Shot</h3>
          <p class="text-stone-500 text-sm">Show examples to guide the output.</p>
        </a>
        
        <a href="/learn/techniques/cot" class="card-gradient rounded-lg p-5 hover:border-stone-600 transition-colors">
          <div class="text-stone-500 text-xs mb-2">03</div>
          <h3 class="text-base font-medium mb-1 text-stone-200">Chain-of-Thought</h3>
          <p class="text-stone-500 text-sm">Ask for step-by-step reasoning.</p>
        </a>
        
        <a href="/learn/techniques/role" class="card-gradient rounded-lg p-5 hover:border-stone-600 transition-colors">
          <div class="text-stone-500 text-xs mb-2">04</div>
          <h3 class="text-base font-medium mb-1 text-stone-200">Role-Based</h3>
          <p class="text-stone-500 text-sm">Assign a persona or expertise.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="card-gradient rounded-2xl p-8 text-center">
        <h2 class="text-xl font-semibold mb-3 text-stone-200">Want real examples?</h2>
        <p class="text-stone-400 mb-6 text-sm">
          Browse system prompts from real tools and compare how each flavor is tuned.
        </p>
        <a href="/learn/real-world-prompts" class="inline-block px-5 py-2.5 rounded-lg bg-stone-100 text-stone-900 font-medium text-sm hover:bg-stone-200 transition-colors">
          Explore Real Prompts
        </a>
      </div>
    </div>
  </section>
</Layout>
