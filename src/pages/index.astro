---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Master AI Prompting">
  <div class="relative overflow-hidden">
    <!-- Background pattern -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/20 via-slate-900 to-slate-900"></div>
    <div class="absolute inset-0" style="background-image: radial-gradient(rgba(51, 65, 85, 0.3) 1px, transparent 1px); background-size: 40px 40px;"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm mb-8">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          Start your prompting journey
        </div>
        
        <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">
          <span class="text-white">Master the </span>
          <span class="gradient-text">Art of Prompting</span>
        </h1>
        
        <p class="text-xl text-slate-400 mb-10 max-w-2xl mx-auto">
          Learn to communicate effectively with AI models. From fundamentals to advanced techniques, 
          build skills that transform how you work with ChatGPT, Claude, Gemini, and more.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/learn" class="px-8 py-4 rounded-xl bg-gradient-to-r from-emerald-500 to-cyan-500 text-slate-900 font-semibold text-lg hover:opacity-90 transition-all glow-emerald">
            Start Learning
          </a>
          <a href="/playground" class="px-8 py-4 rounded-xl bg-slate-800 border border-slate-700 text-white font-semibold text-lg hover:bg-slate-700 transition-all">
            Try Playground
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Core Principles -->
  <section class="py-20 bg-slate-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Three Pillars of Effective Prompts</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">Every great prompt is built on these three principles</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="card-gradient rounded-2xl p-8 glow-emerald">
          <div class="w-14 h-14 rounded-xl bg-emerald-500/20 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Provide Context</h3>
          <p class="text-slate-400">
            Give AI the background it needs. Explain who you are, what you're working on, 
            and what specific outcome you want. Context is the foundation of quality responses.
          </p>
        </div>
        
        <div class="card-gradient rounded-2xl p-8 glow-cyan">
          <div class="w-14 h-14 rounded-xl bg-cyan-500/20 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Be Specific</h3>
          <p class="text-slate-400">
            Vague prompts produce vague results. Specify format, length, tone, and constraints. 
            The more precise you are, the better the AI can deliver exactly what you need.
          </p>
        </div>
        
        <div class="card-gradient rounded-2xl p-8" style="box-shadow: 0 0 40px rgba(139, 92, 246, 0.15);">
          <div class="w-14 h-14 rounded-xl bg-violet-500/20 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Iterate & Refine</h3>
          <p class="text-slate-400">
            First attempts are starting points. Build on good responses, clarify ambiguities, 
            and refine based on output. Prompting is an iterative conversation, not a one-shot command.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Start Techniques -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Core Techniques</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">Master these fundamentals to dramatically improve your outputs</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/learn/techniques/zeroshot" class="card-gradient rounded-xl p-6 hover:border-emerald-500/50 transition-all group">
          <div class="text-emerald-400 font-mono text-sm mb-2">01</div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-emerald-400 transition-colors">Zero-Shot</h3>
          <p class="text-slate-400 text-sm">Direct instructions without examples. Works well for simple, well-defined tasks.</p>
        </a>
        
        <a href="/learn/techniques/fewshot" class="card-gradient rounded-xl p-6 hover:border-cyan-500/50 transition-all group">
          <div class="text-cyan-400 font-mono text-sm mb-2">02</div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-cyan-400 transition-colors">Few-Shot</h3>
          <p class="text-slate-400 text-sm">Provide examples to guide format and style. Perfect for consistent outputs.</p>
        </a>
        
        <a href="/learn/techniques/cot" class="card-gradient rounded-xl p-6 hover:border-violet-500/50 transition-all group">
          <div class="text-violet-400 font-mono text-sm mb-2">03</div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-violet-400 transition-colors">Chain-of-Thought</h3>
          <p class="text-slate-400 text-sm">Ask for step-by-step reasoning. Essential for complex math and logic problems.</p>
        </a>
        
        <a href="/learn/techniques/role" class="card-gradient rounded-xl p-6 hover:border-amber-500/50 transition-all group">
          <div class="text-amber-400 font-mono text-sm mb-2">04</div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-amber-400 transition-colors">Role-Based</h3>
          <p class="text-slate-400 text-sm">Assign a persona or expertise. Shapes tone and depth of response.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Resources Section -->
  <section class="py-20 bg-slate-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Built with Expert Resources</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">Curated content from leading AI companies and institutions</p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="card-gradient rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-emerald-500/20 flex items-center justify-center">
              <span class="text-emerald-400 font-bold">P</span>
            </div>
            <h3 class="font-semibold">Prompting Guide</h3>
          </div>
          <p class="text-slate-400 text-sm">Comprehensive techniques from zero-shot to Tree of Thoughts</p>
        </div>
        
        <div class="card-gradient rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center">
              <span class="text-cyan-400 font-bold">A</span>
            </div>
            <h3 class="font-semibold">Anthropic (Claude)</h3>
          </div>
          <p class="text-slate-400 text-sm">Best practices for clarity, XML tags, and effective prompting</p>
        </div>
        
        <div class="card-gradient rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-violet-500/20 flex items-center justify-center">
              <span class="text-violet-400 font-bold">O</span>
            </div>
            <h3 class="font-semibold">OpenAI (GPT-5.2)</h3>
          </div>
          <p class="text-slate-400 text-sm">Latest patterns for enterprise and agentic workflows</p>
        </div>
        
        <div class="card-gradient rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-amber-500/20 flex items-center justify-center">
              <span class="text-amber-400 font-bold">M</span>
            </div>
            <h3 class="font-semibold">MIT Sloan</h3>
          </div>
          <p class="text-slate-400 text-sm">Academic framework: Context, Specificity, Iterate</p>
        </div>
        
        <div class="card-gradient rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-blue-500/20 flex items-center justify-center">
              <span class="text-blue-400 font-bold">G</span>
            </div>
            <h3 class="font-semibold">Google Cloud</h3>
          </div>
          <p class="text-slate-400 text-sm">Prompt engineering strategies and use case examples</p>
        </div>
        
        <div class="card-gradient rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-rose-500/20 flex items-center justify-center">
              <span class="text-rose-400 font-bold">C</span>
            </div>
            <h3 class="font-semibold">Cline</h3>
          </div>
          <p class="text-slate-400 text-sm">Developer-focused prompting for code and debugging</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="card-gradient rounded-3xl p-12 text-center glow-emerald">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Practice?</h2>
        <p class="text-slate-400 mb-8 max-w-xl mx-auto">
          Head to the playground to experiment with prompts, or check out exercises to test your skills.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/playground" class="px-8 py-4 rounded-xl bg-gradient-to-r from-emerald-500 to-cyan-500 text-slate-900 font-semibold hover:opacity-90 transition-all">
            Open Playground
          </a>
          <a href="/exercises" class="px-8 py-4 rounded-xl bg-slate-800 border border-slate-700 text-white font-semibold hover:bg-slate-700 transition-all">
            View Exercises
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
