---
import Layout from '../layouts/Layout.astro';
import PromptLibrary from '../components/PromptLibrary';
---

<Layout title="My Prompts">
  <div class="py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="gradient-text">My Prompts</span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto">
          Your personal library of effective prompts
        </p>
      </div>

      <PromptLibrary client:load />

      <!-- Tips -->
      <div class="mt-12 card-gradient rounded-xl p-6">
        <h2 class="text-lg font-semibold mb-4">Tips for Building Your Prompt Library</h2>
        <ul class="space-y-3 text-slate-400 text-sm">
          <li class="flex gap-2">
            <span class="text-emerald-400">•</span>
            <span>Save prompts that produce consistently good results</span>
          </li>
          <li class="flex gap-2">
            <span class="text-emerald-400">•</span>
            <span>Add notes about when to use each prompt</span>
          </li>
          <li class="flex gap-2">
            <span class="text-emerald-400">•</span>
            <span>Organize by use case for easy retrieval</span>
          </li>
          <li class="flex gap-2">
            <span class="text-emerald-400">•</span>
            <span>Iterate and improve prompts over time</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
