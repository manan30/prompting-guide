---
import Layout from '../layouts/Layout.astro';
import PromptLibrary from '../components/PromptLibrary';
---

<Layout title="My Notes">
  <div class="py-12 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="gradient-text">My Notes</span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto">
          Your personal collection of prompts that work well for you
        </p>
      </div>

      <PromptLibrary client:load />

      <!-- Tips -->
      <div class="mt-12 card-gradient rounded-lg p-5">
        <h2 class="text-base font-medium mb-3 text-stone-200">Tips for your notes</h2>
        <ul class="space-y-2 text-stone-400 text-sm">
          <li class="flex gap-2">
            <span class="text-stone-500">•</span>
            <span>Save prompts that produce consistently good results</span>
          </li>
          <li class="flex gap-2">
            <span class="text-stone-500">•</span>
            <span>Add notes about when to use each prompt</span>
          </li>
          <li class="flex gap-2">
            <span class="text-stone-500">•</span>
            <span>Organize by use case for easy retrieval</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
